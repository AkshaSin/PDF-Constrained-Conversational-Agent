# .env.example — Copy this to .env and fill in your values
# NEVER commit your real .env file to git (it's already in .gitignore)

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Google Gemini API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Redis connection URL
# Local dev (after: docker run -d -p 6379:6379 redis):
REDIS_URL=redis://localhost:6379
# Redis Cloud free tier example:
# REDIS_URL=redis://default:yourpassword@redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com:12345
